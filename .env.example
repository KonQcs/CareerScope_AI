APP_NAME=CareerScope_AI
ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/careerscope.db
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_API_BASE_URL=http://localhost:8000
DOCKER_STREAMLIT_API_BASE_URL=http://backend:8000

# Optional PostgreSQL mode.
# Local example:
# DATABASE_URL=postgresql+psycopg://careerscope:careerscope@localhost:5432/careerscope
# Docker Compose example:
# DATABASE_URL=postgresql+psycopg://careerscope:careerscope@postgres:5432/careerscope
POSTGRES_DB=careerscope
POSTGRES_USER=careerscope
POSTGRES_PASSWORD=careerscope
POSTGRES_PORT=5432

# Optional real job API provider credentials.
# Leave blank for local sample-job-only development.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb

# Optional LLM explanation rewriting.
# Leave blank to use deterministic template explanations only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
